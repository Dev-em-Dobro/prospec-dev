// Espelha /specs/01-domain-model.md.
// Linguagem ubíqua: Lead, Diagnostico, Dor, Outreach. Snake_case nos campos
// para bater com a tabela do domain model (CLAUDE.md regra explícita).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  novo
  enriquecido
  priorizado
  contatado
  respondeu
  ganho
  perdido
}

enum TipoDor {
  SEM_SITE
  SITE_LENTO
  SEM_HTTPS
  SEM_RESPOSTA_REVIEWS
}

enum Severidade {
  BAIXA
  MEDIA
  ALTA
}

enum Canal {
  whatsapp
  email
}

model Lead {
  id         String     @id @default(cuid())
  nome       String
  endereco   String
  telefone   String?
  website    String?
  categoria  String
  place_id   String     @unique
  status     LeadStatus @default(novo)
  score      Int        @default(0)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  diagnosticos Diagnostico[]
  dores        Dor[]
  outreaches   Outreach[]
}

model Diagnostico {
  id                    String   @id @default(cuid())
  lead_id               String
  tem_site              Boolean
  performance_mobile    Int?
  tem_https             Boolean?
  tempo_carregamento_ms Int?
  executado_em          DateTime @default(now())

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
}

model Dor {
  id         String     @id @default(cuid())
  lead_id    String
  tipo       TipoDor
  severidade Severidade
  detalhes   String

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
}

model Outreach {
  id        String   @id @default(cuid())
  lead_id   String
  canal     Canal
  conteudo  String
  gerado_em DateTime @default(now())
  enviado   Boolean  @default(false)

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
}
